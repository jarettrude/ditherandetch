{
  "cSpell.words": [
    "astro",
    "Bento",
    "briaai",
    "Cardstock",
    "catan",
    "chaikin",
    "Denoise",
    "Denoises",
    "ditherandetch",
    "huggingface",
    "iconify",
    "isnet",
    "lightbox",
    "Ninke",
    "pagefind",
    "Peucker",
    "playwright",
    "pretrained",
    "RMBG",
    "Steinberg",
    "stucki",
    "stylelint",
    "svelte",
    "tailwindcss",
    "unsharp"
  ],

  // Biome integration
  "biome.enabled": true,
  "editor.defaultFormatter": "biomejs.biome",

  // Stylelint integration (2026 enhanced)
  "stylelint.enable": true,
  "stylelint.validate": ["css", "postcss", "scss", "astro", "svelte"],
  "css.validate": false,
  "stylelint.codeAction.showDisableComment": true,

  // TypeScript settings (2026 enhanced)
  "typescript.preferences.includePackageJsonAutoImports": "on",
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.experimental.tsserver.web.projectWideIntellisense": true,
  "typescript.experimental.tsserver.declarations": true,

  // Astro settings (2026 enhanced)
  "astro.language-server": {
    "astro": {
      "typescript": "enabled",
      "compiler": "enabled"
    }
  },

  // Svelte settings (2026 enhanced)
  "svelte.enable-ts-plugin": true,
  "svelte.askToEnableTelemetry": false,

  // File associations (2026 updated)
  "files.associations": {
    "*.astro": "astro",
    "*.css": "tailwindcss",
    "*.config.ts": "typescript",
    "*.config.js": "javascript"
  },

  // Editor settings (2026 best practices)
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.quickSuggestions": {
    "strings": true,
    "comments": true
  },
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.inlayHints.enabled": "on",
  "editor.inlineSuggest.enabled": true,

  // Git settings (2026 enhanced)
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.enableCommitSigning": false,

  // Testing settings (2026 enhanced)
  "testing.automaticallyOpenPeekView": "failureInVisibleDocument",
  "testing.followRunningTest": true,

  // Accessibility settings (2026 enhanced)
  "accessibility.hideAccessibleView": false,
  "accessibility.signals.lineHasError": {
    "sound": "on"
  },
  "accessibility.signals.lineHasWarning": {
    "sound": "on"
  },

  // Linting on save
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit",
    "source.organizeImports.biome": "explicit",
    "source.fixAll.stylelint": "explicit",
    "source.fixAll.markdownlint": "explicit"
  },

  // 2026 additions for modern development
  "emmet.includeLanguages": {
    "astro": "html",
    "svelte": "html"
  },
  "html.autoClosingTags": true,
  "css.autoClosingTags": true,

  // Performance settings for large projects
  "editor.maxTokenizationLineLength": 20000,
  "typescript.tsserver.maxTsServerMemory": 8192,

  // Security settings
  "security.workspace.trust.enabled": true,
  "security.workspace.trust.untrustedFiles": "open",
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#65c89b",
    "activityBar.background": "#65c89b",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#945bc4",
    "activityBarBadge.foreground": "#e7e7e7",
    "commandCenter.border": "#15202b99",
    "sash.hoverBorder": "#65c89b",
    "statusBar.background": "#42b883",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#359268",
    "statusBarItem.remoteBackground": "#42b883",
    "statusBarItem.remoteForeground": "#15202b",
    "titleBar.activeBackground": "#42b883",
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveBackground": "#42b88399",
    "titleBar.inactiveForeground": "#15202b99"
  },
  "peacock.color": "#42b883"
}
